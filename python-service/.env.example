# Port where this service listens
PORT=8000

# CLIP model name (sentence-transformers compatible)
# clip-ViT-B-32 is fast (~350 MB). For better quality use clip-ViT-L-14 (~900 MB)
CLIP_MODEL=clip-ViT-B-32

# Timeout in seconds when fetching remote hairstyle images (signed GCS URLs)
IMAGE_FETCH_TIMEOUT=15
