PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=3600

# Google Cloud Storage
GCS_BUCKET_NAME=your-bucket-name
GCS_KEYFILE_PATH=./credentials/gcs-credentials.json

# Firebase Cloud Messaging
FIREBASE_KEYFILE_PATH=./credentials/firebase-credentials.json

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# Python AI Microservice (local vision + CLIP)
# Start with: cd python-service && uvicorn main:app --port 8000
PYTHON_AI_SERVICE_URL=http://localhost:8000
