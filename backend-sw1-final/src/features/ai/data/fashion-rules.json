  "occasionRules": [
    {
      "occasion": "formal",
      "keywords": ["reunión", "trabajo", "oficina", "entrevista", "boda", "gala", "cena formal", "presentación", "graduación", "negocios", "corporativo"],
      "preferred": ["dress pants", "button-down shirt", "blazer", "formal shoes", "loafers", "elegant boots", "suit", "pencil skirt"],
      "avoid": ["shorts", "graphic tees", "sneakers", "flip flops", "sportswear", "ripped jeans"],
      "tips": [
        "Prioritize tailored fits over relaxed silhouettes",
        "Stick to a maximum of 3 colors in the outfit",
        "Accessories should be minimal and elegant",
        "Monochromatic looks convey authority"
      ]
    },
    {
      "occasion": "semi-formal",
      "keywords": ["teatro", "cena", "evento social", "aniversario", "cumpleaños", "fiesta elegante"],
      "preferred": ["dark jeans", "chinos", "blouse", "shirt", "ankle boots", "heeled sandals", "blazer optional"],
      "avoid": ["athletic wear", "very casual t-shirts", "flip flops"],
      "tips": [
        "Smart-casual is the target — elevate one piece",
        "A good blazer or structured bag transforms a casual look",
        "Opt for dark-wash denim if wearing jeans"
      ]
    },
    {
      "occasion": "casual",
      "keywords": ["salida", "amigos", "calle", "día libre", "compras", "parque", "café"],
      "preferred": ["jeans", "sneakers", "t-shirt", "hoodie", "casual dress", "shorts"],
      "avoid": [],
      "tips": [
        "Comfort is key — fit still matters",
        "One statement piece (sneakers, bag, jacket) elevates casual outfits",
        "Layering adds visual interest to simple pieces"
      ]
    },
    {
      "occasion": "sport",
      "keywords": ["gimnasio", "deporte", "correr", "entrenamiento", "yoga", "ejercicio"],
      "preferred": ["leggings", "athletic shorts", "sports top", "running shoes", "hoodie", "windbreaker"],
      "avoid": ["jeans", "formal shoes", "heavy accessories"],
      "tips": [
        "Moisture-wicking fabrics for performance",
        "Compression fits support movement",
        "Bright or reflective accents for visibility outdoors"
      ]
    }
  ],

  "bodyTypeGuidelines": {
    "PEAR": {
      "emphasize": "shoulders and upper body",
      "tips": ["A-line skirts balance wider hips", "Boat neck or wide-collar tops draw attention up", "Dark bottoms minimize lower half", "Structured jackets add width to shoulders"]
    },
    "RECTANGLE": {
      "emphasize": "create curves",
      "tips": ["Belted waists define silhouette", "Ruffles and peplum tops add volume", "High-waisted bottoms create shape", "Layering adds dimension"]
    },
    "HOURGLASS": {
      "emphasize": "defined waist",
      "tips": ["Wrap dresses and tops highlight curves", "Fitted silhouettes work best", "Avoid oversized or boxy styles that hide shape", "High-waisted bottoms enhance waist definition"]
    },
    "APPLE": {
      "emphasize": "legs and décolletage",
      "tips": ["Empire waist dresses flow from bust down", "V-necks elongate the torso", "Dark tops with light or pattern bottoms balance proportions", "Structured outerwear creates shape"]
    },
    "INVERTED_TRIANGLE": {
      "emphasize": "balance shoulders with hips",
      "tips": ["Wide-leg or flared pants add volume below", "Avoid horizontal stripes on shoulders", "Patterned or detailed bottoms draw eye down", "Avoid shoulder pads and cap sleeves"]
    }
  },

