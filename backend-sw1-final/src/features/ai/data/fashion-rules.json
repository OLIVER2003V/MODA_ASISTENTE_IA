    { "base": "grey",         "complementary": ["navy", "white", "blush", "burgundy", "olive"],        "avoid": ["brown"] },
    { "base": "beige",        "complementary": ["white", "navy", "brown", "olive", "rust"],            "avoid": ["yellow", "neon"] },
